# Salin file ini menjadi .env dan isi nilainya sebelum menjalankan aplikasi

# Kunci rahasia untuk session (ganti dengan string acak yang panjang)
SESSION_SECRET=ganti_dengan_string_rahasia_yang_panjang_dan_acak

# Port server
PORT=3000

# Base URL aplikasi (dipakai untuk membuat link verifikasi email)
BASE_URL=http://localhost:3000

# Kunci enkripsi untuk data sensitif (harus 32 byte / 64 karakter hex)
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=ganti_dengan_hasil_generate_32_byte_hex

# --- Konfigurasi SMTP Gmail (gunakan App Password, bukan password akun biasa) ---
# Contoh untuk Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=namaakun@gmail.com
# SMTP_PASS=16_digit_app_password
# SMTP_FROM="Secure Webapp <namaakun@gmail.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
